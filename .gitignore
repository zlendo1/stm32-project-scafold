# ============================================================
# .gitignore for STM32CubeMX project
# ============================================================
# Philosophy: Track source code and project config, ignore all
# generated/regeneratable files. CubeMX can regenerate everything
# from the .ioc file except user code in Core/.

# =============================================================
# TRACKED (not ignored):
# =============================================================
# - Core/              User source code
# - *.ioc              CubeMX project file (regenerates everything)
# - CMakeLists.txt     CMake build config
# - CMakePresets.json  CMake presets
# - cmake/             CMake modules
# - STM32*.ld          Linker script (may contain user modifications)
# - startup_*.s        Startup assembly (may contain user modifications)

# =============================================================
# CubeMX GENERATED (regenerated from .ioc)
# =============================================================
# HAL drivers, CMSIS, middleware - all regenerated by CubeMX
Drivers/
Middlewares/
USB_DEVICE/
FATFS/
LWIP/
MBEDTLS/
TouchGFX/
AZURE_RTOS/

# CubeMX metadata
.mxproject

# =============================================================
# BUILD OUTPUT
# =============================================================
build/
Debug/
Release/
out/

# Binary outputs
*.elf
*.bin
*.hex
*.map
*.lst
*.axf
*.a
*.out

# Object & dependency files
*.o
*.d
*.su

# =============================================================
# CMAKE GENERATED
# =============================================================
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
cmake-build-*/
compile_commands.json
CTestTestfile.cmake
_deps/
Makefile

# =============================================================
# IDE: STM32CubeIDE
# =============================================================
.cproject
.project
.settings/
.metadata/
*.launch

# =============================================================
# IDE: Keil MDK (uVision)
# =============================================================
*.uvoptx
*.uvguix
*.uvprojx
*.scvd
Listings/
Objects/
RTE/

# =============================================================
# IDE: IAR Embedded Workbench
# =============================================================
*.ewt
*.ewd
*.dep
*.xcl
*.cspy.*
*.dbgdt
settings/

# =============================================================
# IDE: VS Code
# =============================================================
.vscode/

# =============================================================
# DEBUGGER / PROGRAMMER
# =============================================================
*.svd
*.cfg
*.jlink
*.flashloader
JLinkLog.txt
JLinkSettings.ini
openocd.log
STLink_gdbserver.log
flash.ini

# =============================================================
# BACKUP & TEMP
# =============================================================
*.bak
*.orig
*.tmp
*.swp
*.swo
*~
*.log

# =============================================================
# OS GENERATED
# =============================================================
.DS_Store
Thumbs.db
desktop.ini
