# ============================================================
# .gitignore for STM32F3DISCOVERY CMake project
# ============================================================
# Track source code and project config. Ignore all generated /
# regeneratable files. CubeMX regenerates Drivers/ and Middlewares/
# from the .ioc file; user code lives in Core/.

# =============================================================
# CubeMX GENERATED (regenerated from .ioc)
# =============================================================
# HAL drivers, CMSIS, middleware - all regenerated by CubeMX
Drivers/
Middlewares/
USB_DEVICE/
FATFS/
LWIP/
MBEDTLS/
TouchGFX/
AZURE_RTOS/

# CubeMX metadata
.mxproject

# =============================================================
# BUILD OUTPUT
# =============================================================
build/
Debug/
Release/
out/

# Binary outputs
*.elf
*.bin
*.hex
*.map
*.lst
*.axf
*.a
*.out

# Object & dependency files
*.o
*.d
*.su

# =============================================================
# CMAKE GENERATED
# =============================================================
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
cmake-build-*/
compile_commands.json
CTestTestfile.cmake
_deps/
Makefile

# =============================================================
# IDE: STM32CubeIDE
# =============================================================
.cproject
.project
.settings/
.metadata/
*.launch

# =============================================================
# IDE: Keil MDK (uVision)
# =============================================================
*.uvoptx
*.uvguix
*.uvprojx
*.scvd
Listings/
Objects/
RTE/

# =============================================================
# IDE: IAR Embedded Workbench
# =============================================================
*.ewt
*.ewd
*.dep
*.xcl
*.cspy.*
*.dbgdt
settings/

# =============================================================
# IDE: VS Code
# =============================================================
.vscode/

# =============================================================
# DEBUGGER / PROGRAMMER
# =============================================================
*.svd
*.cfg
*.jlink
*.flashloader
JLinkLog.txt
JLinkSettings.ini
openocd.log
STLink_gdbserver.log
flash.ini

# =============================================================
# BACKUP & TEMP
# =============================================================
*.bak
*.orig
*.tmp
*.swp
*.swo
*~
*.log

# =============================================================
# OS GENERATED
# =============================================================
.DS_Store
Thumbs.db
desktop.ini
